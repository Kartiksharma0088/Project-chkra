import cv2
import mediapipe as mp
import numpy as np
import math

class GestureRecognizer:
    def __init__(self):
        self.mp_hands = mp.solutions.hands
        self.hands = self.mp_hands.Hands(
            static_image_mode=False,
            max_num_hands=2,
            min_detection_confidence=0.5,
            min_tracking_confidence=0.5
        )
        self.mp_drawing = mp.solutions.drawing_utils
        
    def calculate_distance(self, point1, point2):
        """Calculate Euclidean distance between two points"""
        return math.sqrt((point1[0] - point2[0])**2 + (point1[1] - point2[1])**2)
    
    def is_thumbs_up(self, landmarks):
        """Detect thumbs up gesture"""
        thumb_tip = landmarks[4]
        thumb_ip = landmarks[3]
        middle_finger_pip = landmarks[10]
        
        # Thumb should be above other fingers
        if thumb_tip.y < thumb_ip.y < middle_finger_pip.y:
            return True
        return False
    
    def is_ok_sign(self, landmarks):
        """Detect OK gesture (thumb and index touching, other fingers spread)"""
        thumb_tip = landmarks[4]
        index_tip = landmarks[8]
        
        distance = self.calculate_distance(
            (thumb_tip.x, thumb_tip.y),
            (index_tip.x, index_tip.y)
        )
        
        # Check if thumb and index are close
        if distance < 0.05:
            return True
        return False
    
    def is_peace_sign(self, landmarks):
        """Detect peace sign (index and middle fingers up, others down)"""
        index_tip = landmarks[8]
        middle_tip = landmarks[12]
        ring_tip = landmarks[16]
        
        # Index and middle should be higher than ring finger
        if index_tip.y < ring_tip.y and middle_tip.y < ring_tip.y:
            return True
        return False
    
    def is_open_palm(self, landmarks):
        """Detect open palm gesture"""
        wrist = landmarks[0]
        fingers = [landmarks[4], landmarks[8], landmarks[12], landmarks[16], landmarks[20]]
        
        # All fingers should be spread and above wrist
        open_fingers = sum(1 for finger in fingers if finger.y < wrist.y)
        if open_fingers >= 4:
            return True
        return False
    
    def is_waving(self, landmarks):
        """Detect waving gesture"""
        wrist = landmarks[0]
        hand_center_x = np.mean([lm.x for lm in landmarks])
        
        # Hand moving side to side (simplified)
        if abs(hand_center_x - wrist.x) > 0.1:
            return True
        return False
    
    def recognize_gesture(self, hand_landmarks):
        """Recognize gesture from hand landmarks"""
        landmarks = hand_landmarks.landmark
        
        if self.is_thumbs_up(landmarks):
            return "Thumbs Up"
        elif self.is_ok_sign(landmarks):
            return "OK Sign"
        elif self.is_peace_sign(landmarks):
            return "Peace Sign"
        elif self.is_open_palm(landmarks):
            return "Open Palm"
        elif self.is_waving(landmarks):
            return "Waving"
        
        return None
    
    def process_frame(self, frame):
        """Process frame and return gesture and annotated frame"""
        rgb_frame = cv2.cvtColor(frame, cv2.COLOR_BGR2RGB)
        results = self.hands.process(rgb_frame)
        
        gesture = None
        h, w, c = frame.shape
        
        if results.multi_hand_landmarks:
            for hand_landmarks in results.multi_hand_landmarks:
                # Draw hand landmarks
                self.mp_drawing.draw_landmarks(
                    frame,
                    hand_landmarks,
                    self.mp_hands.HAND_CONNECTIONS
                )
                
                # Recognize gesture
                recognized = self.recognize_gesture(hand_landmarks)
                if recognized:
                    gesture = recognized
                    
                    # Draw gesture label
                    landmarks = hand_landmarks.landmark
                    hand_x = int(landmarks[9].x * w)
                    hand_y = int(landmarks[9].y * h)
                    cv2.putText(frame, gesture, (hand_x, hand_y - 10),
                               cv2.FONT_HERSHEY_SIMPLEX, 1, (0, 255, 0), 2)
        
        return gesture, frame
